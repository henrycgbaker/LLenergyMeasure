# Development Dockerfile for web frontend (hot reload)
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm ci

# Copy source code (will be overridden by volume mount)
COPY . .

EXPOSE 5173

# Run dev server
CMD ["npm", "run", "dev", "--", "--host"]
